.DS_Store
# Ad-hoc debug crops produced by `nikkecopilot crop-tool` and the
# arena-extractor diagnostic scripts. Keep out of git history.
/debug/

# Tournament screenshot archive (per-user data, can be GBs).
# Source captures land in /champion_arena and are relocated by
# `nikkeoptimizer ingest-tournaments` into /captures.
/captures/
/champion_arena/

# Claude Code agent settings (per-user, not project state).
/.claude/

# Inbox for raw uploads + per-user capture staging.
/incoming-captures/

# Auto-import daemon audit log + launchd stdout/stderr capture.
/logs/

# Debug-script dump payloads (the .py scripts are tracked; their
# captured response bodies aren't).
/scripts/debug/dumps/
